APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=skill_hub
POSTGRES_USER=xusheng
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+psycopg://xusheng@127.0.0.1:5432/skill_hub
TEST_DATABASE_URL=postgresql+psycopg://xusheng@127.0.0.1:5432/skill_hub_test

# 本地一键栈（infra/scripts/start-local-stack.sh）
DEV_HOST=127.0.0.1
API_PORT=8000
ADMIN_DEV_PORT=5174
PORTAL_DEV_PORT=5173

APP_BASE_URL=http://127.0.0.1:8000

REDIS_URL=redis://127.0.0.1:6379/0

S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=local-dev
S3_SECRET_KEY=local-dev
S3_BUCKET=skill-hub
S3_REGION=us-east-1
S3_SECURE=false
S3_PRESIGN_EXPIRE_SECONDS=300
STORAGE_BACKEND=local
FILE_STORAGE_PATH=.runtime/local-dev/storage
# 技能包存储子路径（相对 FILE_STORAGE_PATH）；详见 docs/30-product-flows/upload-review-release.md
SKILL_PACKAGE_UPLOAD_SUBDIR=upload-packages
SKILL_README_SUBDIR=readmes
SKILL_PACKAGE_DISTRIBUTION_SUBDIR=distribution-packages

JWT_SECRET=change-me
# 长期会话：access 约 365 天、refresh 约 10 年（分钟数 = 天×1440）；测试环境可在 conftest 覆写为短时效
JWT_ACCESS_EXPIRE_MINUTES=525600
JWT_REFRESH_EXPIRE_DAYS=3650
REQUEST_ID_HEADER=X-Request-ID
LOGIN_RATE_LIMIT=10/minute
# 主系统跳转门户单点登录；生产若不用请设为 false
SSO_PORTAL_ENABLED=true
SSO_PORTAL_RATE_LIMIT=30/minute
UPLOAD_RATE_LIMIT=20/hour
DOWNLOAD_RATE_LIMIT=120/hour
CATEGORIES_CACHE_TTL_SECONDS=60
SKILL_DETAIL_CACHE_TTL_SECONDS=60

PORTAL_WEB_URL=http://127.0.0.1:5173
ADMIN_WEB_URL=http://127.0.0.1:5174
API_BASE_URL=http://127.0.0.1:8000
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:4173,http://127.0.0.1:4174
CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:4173,http://127.0.0.1:4174
VITE_API_BASE_URL=http://127.0.0.1:8000/api
VITE_ADMIN_WEB_URL=http://127.0.0.1:5174
